<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="#675247" />
            <corners android:radius="19.0dp" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <scale android:scaleWidth="100%">
            <shape>
                <corners android:radius="16.0dp" />
                <solid android:color="#d6ae7b" />
                <stroke android:width="2.0dp" android:color="#675247" />
            </shape>
        </scale>
    </item>
</layer-list>
